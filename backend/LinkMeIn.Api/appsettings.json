{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=LinkMeIn;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "LinkedIn": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "https://localhost:7001/api/linkedin/oauth/callback",
    "AuthorizationEndpoint": "https://www.linkedin.com/oauth/v2/authorization",
    "TokenEndpoint": "https://www.linkedin.com/oauth/v2/accessToken",
    "Scopes": [
      "openid",
      "profile",
      "email",
      "w_member_social"
    ]
  },
  "TokenEncryption": {
    "KeyId": "local-development",
    "Key": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MediaStorage": {
    "RootPath": "App_Data/media",
    "MaxFileSizeBytes": 2097152,
    "MaxImagesPerPost": 4,
    "AllowedContentTypes": [
      "image/jpeg",
      "image/png",
      "image/webp"
    ]
  }
}
